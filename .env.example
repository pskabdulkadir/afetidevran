# ÜCRETSİZ ve SINIRSIZ AÇIK KAYNAK APİ'LER (Herhangi bir Gemini API anahtarı veya ücretli katman gerekmez)

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PRIVATE_KEY: The deployer wallet private key for deploying the contract to the Polygon network.
PRIVATE_KEY=""

# EMERGENCY_BACKUP_WALLET: Security fallback address to sweep/evacuate funds during sweep attacks (for Asker 2: Cüzdan Kalkanı)
EMERGENCY_BACKUP_WALLET="0xGüvenliYedekCüzdanAdresiniz"

# RENDER_EXTERNAL_URL: The external deployment URL hosted on Render to prevent cold-starts via anti-sleep pingers
RENDER_EXTERNAL_URL="https://afeti-devran-v5.onrender.com"

# POLYGON_ARCHIVE_URL: Optional high-availability RPC node for Hardhat Polygon mainnet forking.
POLYGON_ARCHIVE_URL="https://polygon-rpc.com"

# CONTRACT_ADDRESS: Deployed arbitrage contract address on Polygon mainnet (Siber Karargâh authorization)
CONTRACT_ADDRESS="0x69b48825DA1e62b76DCFab0201bDe0a1752a3841"

# FORCE_EXECUTION_THRESHOLD: Force execution even with minimal profit (Siber Karargâh mode). Set to 0.00000000001 for testing
FORCE_EXECUTION_THRESHOLD="0"

# MIN_PROFIT_THRESHOLD: Minimum net profit in USD required for automatic execution (default: 0.5)
# Set higher to avoid losing money on gas fees
MIN_PROFIT_THRESHOLD="0.5"

# SKIP_PROFIT_CHECK: Bypass profit check and execute regardless (true/false)
SKIP_PROFIT_CHECK="false"

# MAX_GAS_THRESHOLD: Maximum gas limit for transactions
MAX_GAS_THRESHOLD="500000"
